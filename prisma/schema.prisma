generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Transaction {
  id               Int      @id @default(autoincrement())
  userId           String
  tipo             String
  descricao        String
  produto          String?
  categoria        String?
  quantidade       Float?
  valorUnitario    Float?
  valorTotal       Float
  formaPagamento   String?
  data             DateTime
  mensagemOriginal String?
  createdAt        DateTime @default(now())

  @@index([userId])
}
