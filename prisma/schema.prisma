generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Transaction {
  id               Int       @id @default(autoincrement())
  userId           String
  tipo             String
  descricao        String
  produto          String?
  categoria        String?
  quantidade       Float?
  valorUnitario    Float?
  valorTotal       Float
  formaPagamento   String?
  statusPagamento  String?
  data             DateTime
  mensagemOriginal String?
  clienteId        Int?
  fornecedorId     Int?
  createdAt        DateTime  @default(now())

  cliente    Cliente?    @relation(fields: [clienteId], references: [id])
  fornecedor Fornecedor? @relation(fields: [fornecedorId], references: [id])

  @@index([userId])
}

model Cliente {
  id        Int           @id @default(autoincrement())
  userId    String
  nome      String
  telefone  String?
  email     String?
  createdAt DateTime      @default(now())

  transacoes Transaction[]

  @@index([userId])
}

model Fornecedor {
  id        Int           @id @default(autoincrement())
  userId    String
  nome      String
  telefone  String?
  email     String?
  createdAt DateTime      @default(now())

  transacoes Transaction[]

  @@index([userId])
}

model Perfil {
  id           Int      @id @default(autoincrement())
  userId       String   @unique
  nomeNegocio  String
  logoUrl      String?
  updatedAt    DateTime @updatedAt
}
