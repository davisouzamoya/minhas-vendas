generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Transaction {
  id               Int       @id @default(autoincrement())
  userId           String
  tipo             String
  descricao        String
  produto          String?
  categoria        String?
  quantidade       Float?
  valorUnitario    Float?
  valorTotal       Float
  formaPagamento   String?
  statusPagamento  String?
  recorrente       Boolean   @default(false)
  observacoes      String?
  comprovanteUrl   String?
  fotoUrl          String?
  data             DateTime
  mensagemOriginal String?
  clienteId        Int?
  fornecedorId     Int?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime? @updatedAt

  cliente    Cliente?    @relation(fields: [clienteId], references: [id])
  fornecedor Fornecedor? @relation(fields: [fornecedorId], references: [id])

  @@index([userId])
}

model Cliente {
  id          Int           @id @default(autoincrement())
  userId      String
  nome        String
  telefone    String?
  email       String?
  aniversario DateTime?     @db.Date
  ativo       Boolean       @default(true)
  createdAt   DateTime      @default(now())

  transacoes Transaction[]

  @@index([userId])
}

model Fornecedor {
  id        Int           @id @default(autoincrement())
  userId    String
  nome      String
  telefone  String?
  email     String?
  ativo     Boolean       @default(true)
  createdAt DateTime      @default(now())

  transacoes Transaction[]

  @@index([userId])
}

model Perfil {
  id           Int       @id @default(autoincrement())
  userId       String    @unique
  nomeNegocio  String
  logoUrl      String?
  categorias   Json?
  role         String    @default("user")
  metaMensal   Float?
  plan                  String    @default("gratuito")
  trialEndsAt           DateTime?
  stripeCustomerId      String?
  stripeSubscriptionId  String?
  updatedAt             DateTime  @updatedAt
}

model Produto {
  id            Int      @id @default(autoincrement())
  userId        String
  nome          String
  descricao     String?
  categoria     String?
  preco         Float?
  precoCusto    Float?
  estoque       Float    @default(0)
  estoqueMinimo Float?
  unidade       String?
  ativo         Boolean  @default(true)
  fotoUrl       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
}
